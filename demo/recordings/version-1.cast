[149.581265, "o", "\u001b[?25l\u001b[2;82H=== ÉTAT DÉSIRÉ (apps.json) ===\u001b[K\u001b[3;82Hduck-1: {\"image\": \"nginx:alpine\"}\u001b[K\u001b[4;82Hduck-2: {\"image\": \"nginx:alpine\"}\u001b[K\u001b[5;82Hduck-3: {\"image\": \"nginx:alpine\"}\u001b[K\u001b[6;82Hduck-4: {\"image\": \"nginx:alpine\"}\u001b[K\u001b[7;82H\u001b[K\n=== APPS EN COURS ===\u001b[K\u001b[9;82H\u001b[K\n**node-1**\u001b[K\u001b[11;82H\u001b[2X\u001b[2Cduck-4\u001b[8X\u001b[8CAbout a minute ago\u001b[K\u001b[12;82H\u001b[2X\u001b[2Cduck-1\u001b[8X\u001b[8CLess than a second ago\u001b[K\u001b[13;82H\u001b[K\n**node-2**\u001b[K\u001b[15;82H\u001b[2X\u001b[2Cduck-3        About a minute ago\u001b[K\u001b[16;82H\u001b[2X\u001b[2Cduck-2\u001b[8X\u001b[8CLess than a second ago\u001b[K\u001b[17;82H\u001b[K\n**node-3**\u001b[K\u001b[19;82H\u001b[2X\u001b[2C(aucune app)\u001b[K\u001b[20;82H\u001b[K\n\u001b[K\n\u001b[K\n\u001b[K\n\u001b[K\n\u001b[K\n\u001b[K\n\u001b[K\n\u001b[K\n\u001b[K\n\u001b[K\n\u001b[K\n\u001b[K\n\u001b[K\n\u001b[K\u001b[?12l\u001b[?25h\u001b[43;5H"]
